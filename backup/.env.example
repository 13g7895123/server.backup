# 複製此檔為 .env 並填入實際值
PG_PASSWORD=your_secure_password_here

# 對外 PORT
DASHBOARD_PORT=8105

# Agent 與 Dashboard 的通訊設定
# Host agent 透過 HTTP API 與 dashboard 溝通，PostgreSQL 不對外暴露
DASHBOARD_URL=http://127.0.0.1:8105
AGENT_TOKEN=          # 選填：若設定則 agent 須帶此值於 X-Agent-Token header

# Slack 失敗通知（選填）
SLACK_WEBHOOK_URL=
